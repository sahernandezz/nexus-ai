# ─── NexusAI Environment Variables ───────────────────────────────────────────
# Copy this file to .env and fill in real values.
# IMPORTANT: .env is git-ignored. Never commit real secrets.

# ─── Database ─────────────────────────────────────────────────────────────────
DB_NAME=nexusai
DB_USER=nexusai
DB_PASSWORD=nexusai_dev_password

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=

# ─── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Minimum 32 characters. Generate a strong key for production:
# $ openssl rand -hex 32
JWT_SECRET=change-this-to-a-strong-secret-minimum-32-chars

# ─── OpenAI ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here

# ─── Grafana ──────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ─── MinIO (Object Storage) ───────────────────────────────────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin


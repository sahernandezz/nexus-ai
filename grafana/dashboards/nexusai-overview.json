{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "NexusAI Spring Boot metrics — HTTP, JVM, LLM calls, document ingestion",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "🔥 HTTP",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.5 },
            { "color": "red", "value": 1 }
          ]},
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "HTTP Request Rate",
      "type": "stat",
      "targets": [{ "expr": "sum(rate(http_server_requests_seconds_count{application=\"nexusai-backend\"}[1m]))", "legendFormat": "req/s", "datasource": { "type": "prometheus", "uid": "prometheus" } }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 500 },
            { "color": "red", "value": 2000 }
          ]},
          "unit": "ms"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "HTTP P99 Latency",
      "type": "stat",
      "targets": [{ "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{application=\"nexusai-backend\"}[5m])) by (le)) * 1000", "legendFormat": "P99 ms", "datasource": { "type": "prometheus", "uid": "prometheus" } }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.01 },
            { "color": "red", "value": 0.05 }
          ]},
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "HTTP Error Rate (5xx)",
      "type": "stat",
      "targets": [{ "expr": "sum(rate(http_server_requests_seconds_count{application=\"nexusai-backend\",status=~\"5..\"}[5m])) / sum(rate(http_server_requests_seconds_count{application=\"nexusai-backend\"}[5m]))", "legendFormat": "Error %", "datasource": { "type": "prometheus", "uid": "prometheus" } }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "id": 10,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "HTTP Requests per Endpoint",
      "type": "timeseries",
      "targets": [{ "expr": "sum by (uri, method, status) (rate(http_server_requests_seconds_count{application=\"nexusai-backend\"}[1m]))", "legendFormat": "{{method}} {{uri}} {{status}}", "datasource": { "type": "prometheus", "uid": "prometheus" } }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "id": 11,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "HTTP Latency Percentiles (P50/P95/P99)",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{application=\"nexusai-backend\"}[5m])) by (le))", "legendFormat": "P50", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"nexusai-backend\"}[5m])) by (le))", "legendFormat": "P95", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{application=\"nexusai-backend\"}[5m])) by (le))", "legendFormat": "P99", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "id": 101,
      "title": "🤖 LLM / AI",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "id": 20,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "LLM Request Rate by Provider",
      "type": "timeseries",
      "targets": [{ "expr": "sum by (provider, outcome) (rate(nexusai_llm_requests_total[1m]))", "legendFormat": "{{provider}} — {{outcome}}", "datasource": { "type": "prometheus", "uid": "prometheus" } }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "id": 21,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "LLM Latency P95 by Provider",
      "type": "timeseries",
      "targets": [{ "expr": "histogram_quantile(0.95, sum by (provider, le) (rate(nexusai_llm_latency_seconds_bucket[5m])))", "legendFormat": "{{provider}} P95", "datasource": { "type": "prometheus", "uid": "prometheus" } }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "id": 22,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "LLM Tokens (prompt vs completion)",
      "type": "timeseries",
      "targets": [{ "expr": "sum by (provider, type) (rate(nexusai_llm_tokens_total[5m]))", "legendFormat": "{{provider}} {{type}}", "datasource": { "type": "prometheus", "uid": "prometheus" } }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 30 },
      "id": 102,
      "title": "☕ JVM",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes", "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 31 },
      "id": 30,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "JVM Memory Used",
      "type": "timeseries",
      "targets": [{ "expr": "sum by (area) (jvm_memory_used_bytes{application=\"nexusai-backend\"})", "legendFormat": "{{area}}", "datasource": { "type": "prometheus", "uid": "prometheus" } }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.7 }, { "color": "red", "value": 0.9 }] }, "min": 0, "max": 1 } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 31 },
      "id": 31,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "CPU Usage",
      "type": "timeseries",
      "targets": [{ "expr": "system_cpu_usage{application=\"nexusai-backend\"}", "legendFormat": "System CPU", "datasource": { "type": "prometheus", "uid": "prometheus" } }, { "expr": "process_cpu_usage{application=\"nexusai-backend\"}", "legendFormat": "Process CPU", "datasource": { "type": "prometheus", "uid": "prometheus" } }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 39 },
      "id": 32,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "JVM Threads",
      "type": "timeseries",
      "targets": [{ "expr": "jvm_threads_live_threads{application=\"nexusai-backend\"}", "legendFormat": "Live", "datasource": { "type": "prometheus", "uid": "prometheus" } }, { "expr": "jvm_threads_daemon_threads{application=\"nexusai-backend\"}", "legendFormat": "Daemon", "datasource": { "type": "prometheus", "uid": "prometheus" } }, { "expr": "jvm_threads_peak_threads{application=\"nexusai-backend\"}", "legendFormat": "Peak", "datasource": { "type": "prometheus", "uid": "prometheus" } }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 39 },
      "id": 33,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "GC Pause Duration",
      "type": "timeseries",
      "targets": [{ "expr": "sum by (gc) (rate(jvm_gc_pause_seconds_sum{application=\"nexusai-backend\"}[1m]))", "legendFormat": "{{gc}}", "datasource": { "type": "prometheus", "uid": "prometheus" } }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 47 },
      "id": 103,
      "title": "📦 R2DBC / Database",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 48 },
      "id": 40,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "R2DBC Connection Pool",
      "type": "timeseries",
      "targets": [
        { "expr": "r2dbc_pool_acquired_connections{application=\"nexusai-backend\"}", "legendFormat": "Acquired", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "expr": "r2dbc_pool_idle_connections{application=\"nexusai-backend\"}", "legendFormat": "Idle", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "expr": "r2dbc_pool_max_allocated_connections{application=\"nexusai-backend\"}", "legendFormat": "Max", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["nexusai", "spring-boot", "ai"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "NexusAI — Overview",
  "uid": "nexusai-overview",
  "version": 1
}

